---
interface Props {
  howToBuy: {
    eyebrow: string;
    heading: string;
    subtitle: string;
    steps: { n: string; title: string; text: string }[];
    payments: string[];
    deliveryNote: string;
    deliveryRegion: string;
    ctaButton: string;
    ctaButtonHref: string;
  };
  whatsappNumber: string;
}

const { howToBuy, whatsappNumber } = Astro.props;
const waDefault = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Olá! Tenho interesse no Conjunto Térmico da Olic Kids')}`;
const ctaHref = howToBuy.ctaButtonHref || waDefault;
---

<section style="padding: clamp(64px, 10vw, 120px) 0; background: var(--soft-white);">
  <div class="wrap">

    <!-- Cabeçalho -->
    <div class="reveal" style="text-align: center; display: grid; justify-items: center; margin-bottom: 50px;">
      <div style="display: inline-flex; align-items: center; gap: 10px; justify-content: center;">
        <img src="/images/dog_taupe.png" alt="" style="width: 26px; opacity: 0.9;" />
        <span style="font-size: 12.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--taupe);">{howToBuy.eyebrow}</span>
      </div>
      <h2 style="font-size: clamp(1.9rem, 4.2vw, 2.9rem); margin-top: 14px;">{howToBuy.heading}</h2>
      {howToBuy.subtitle && (
        <p style="color: var(--text); margin-top: 14px; max-width: 500px; font-size: 1.05rem;">{howToBuy.subtitle}</p>
      )}
    </div>

    <!-- Passos -->
    <div class="steps-grid" style="display: grid; gap: 20px; margin-bottom: 44px;">
      {howToBuy.steps.map(({ n, title, text }, i) => (
        <div class="reveal" style={`position: relative; padding: 8px 4px; transition-delay: ${i * 100}ms;`}>
          <div style="font-family: var(--serif); font-size: 3.4rem; color: var(--cream-deep); line-height: 1;">{n}</div>
          <h3 style="font-size: 1.32rem; margin-top: 8px;">{title}</h3>
          <p style="color: var(--text); margin-top: 8px; max-width: 300px;">{text}</p>
        </div>
      ))}
    </div>

    <!-- Formas de pagamento & entrega -->
    <div class="reveal pay-card" style="background: var(--cream); border: 1px solid var(--line); border-radius: var(--radius); padding: 30px; display: grid; gap: 24px;">
      <div class="pay-inner" style="display: grid; gap: 24px; align-items: center;">
        <div>
          <div style="font-size: 12.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--taupe);">Formas de pagamento</div>
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px;">
            {howToBuy.payments.map((p: string) => (
              <span style="display: inline-flex; align-items: center; gap: 8px; background: var(--soft-white); border: 1px solid var(--line); border-radius: 999px; padding: 9px 16px; font-weight: 600; color: var(--brown); font-size: 14.5px;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--taupe)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                {p}
              </span>
            ))}
          </div>
        </div>
        <div style="display: flex; align-items: center; gap: 12px; color: var(--text);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--taupe)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <div style="font-size: 15px;">
            <b style="color: var(--brown);">{howToBuy.deliveryNote}</b><br />
            {howToBuy.deliveryRegion}
          </div>
        </div>
      </div>
    </div>

    <!-- Botão CTA -->
    {howToBuy.ctaButton && (
      <div class="reveal" style="margin-top: 40px; text-align: center;">
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener"
          class="olic-btn olic-btn-whatsapp"
          style="display: inline-flex; align-items: center; gap: 10px; padding: 17px 30px; font-size: 17px; font-weight: 700; border-radius: var(--btn-radius); background: #25D366; color: #fff; border: 1.5px solid transparent; text-decoration: none; line-height: 1.1; white-space: nowrap;"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
          </svg>
          {howToBuy.ctaButton}
        </a>
      </div>
    )}
  </div>
</section>
