---
interface Props {
  finalCta: {
    heading: string;
    subtitle: string;
    ctaButton: string;
    ctaButtonHref: string | null;
    instagramLabel: string;
    instagramHref: string | null;
  };
}

const { finalCta } = Astro.props;
---

<section id="contato" style="padding: clamp(70px, 11vw, 130px) 0; background: var(--brown);">
  <div class="wrap" style="text-align: center; display: grid; justify-items: center;">
    <div class="reveal" style="display: grid; justify-items: center;">
      <img src="/images/dog_taupesoft.png" alt="" style="width: 86px;" />
      <h2 style="font-size: clamp(2.1rem, 5vw, 3.6rem); margin-top: 22px; color: var(--cream);">
        {finalCta.heading}
      </h2>
      <p style="color: rgba(246,241,232,0.82); margin-top: 18px; font-size: 1.12rem; max-width: 480px;">
        {finalCta.subtitle}
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; justify-content: center;">
        <a
          href={finalCta.ctaButtonHref ?? '#'}
          target="_blank"
          rel="noopener"
          class="olic-btn olic-btn-whatsapp"
          style="display: inline-flex; align-items: center; gap: 10px; padding: 17px 30px; font-size: 17px; font-weight: 700; border-radius: var(--btn-radius); background: #25D366; color: #fff; border: 1.5px solid transparent; text-decoration: none; line-height: 1.1; white-space: nowrap;"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/>
          </svg>
          {finalCta.ctaButton}
        </a>
        <a
          href={finalCta.instagramHref ?? '#'}
          target="_blank"
          rel="noopener"
          class="olic-btn"
          style="display: inline-flex; align-items: center; gap: 10px; padding: 17px 30px; font-size: 17px; font-weight: 700; border-radius: var(--btn-radius); background: transparent; color: var(--cream); border: 1.5px solid rgba(246,241,232,0.4); text-decoration: none; line-height: 1.1; white-space: nowrap;"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--cream)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".6" fill="var(--cream)"/>
          </svg>
          {finalCta.instagramLabel}
        </a>
      </div>
    </div>
  </div>
</section>
