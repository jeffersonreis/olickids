---
interface Props {
  story: {
    eyebrow: string;
    heading: string;
    paragraph1: string;
    paragraph2: string;
    quote: string;
    imagePrincipal: string | null;
    imageDetalhe: string | null;
  };
}

const { story } = Astro.props;

function imgSrc(path: string | null, prefix = '/images/story/'): string | null {
  if (!path) return null;
  return path.startsWith('/') ? path : `${prefix}${path}`;
}

const mainSrc = imgSrc(story.imagePrincipal);
const detailSrc = imgSrc(story.imageDetalhe);

function em(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>');
}
---

<section id="historia" style="padding: clamp(70px, 11vw, 130px) 0; background: var(--soft-white);">
  <div class="wrap">
    <div class="story-grid" style="display: grid; gap: 54px; align-items: center;">

      <!-- Coluna de fotos -->
      <div class="reveal" style="position: relative;">

        <!-- Foto principal -->
        {mainSrc ? (
          <img
            src={mainSrc}
            alt={story.heading}
            style="width: 100%; aspect-ratio: 5/6; object-fit: cover; border-radius: var(--radius); border: 1px solid var(--line); display: block;"
          />
        ) : (
          <div style="position: relative; width: 100%; aspect-ratio: 5/6; border-radius: var(--radius); overflow: hidden; background: var(--cream); border: 1px solid var(--line); display: grid; place-items: center;">
            <div style="position: absolute; inset: 0; opacity: 0.5; background-image: repeating-linear-gradient(135deg, transparent 0 14px, rgba(176,154,128,0.07) 14px 15px);"></div>
            <img src="/images/dog_taupe.png" alt="" style="position: absolute; bottom: 18px; right: 18px; width: 120px; opacity: 0.16;" />
            <div style="position: relative; text-align: center; padding: 0 18px; display: grid; gap: 10px; justify-items: center;">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="var(--taupe)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.8">
                <rect x="3" y="4" width="18" height="16" rx="2.5"/><circle cx="8.5" cy="9.5" r="1.6"/><path d="M21 16l-5-5L7 20"/>
              </svg>
              <span style="font-family: ui-monospace, monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--taupe); line-height: 1.5; max-width: 200px;">
                Foto — as duas mães com as crianças
              </span>
            </div>
          </div>
        )}

        <!-- Foto detalhe sobreposta -->
        <div style="position: absolute; width: 44%; right: -16px; bottom: -28px; border-radius: var(--radius); overflow: hidden; box-shadow: 0 20px 50px -24px rgba(90,64,41,0.5);">
          {detailSrc ? (
            <img
              src={detailSrc}
              alt="Detalhe — bordado dachshund"
              style="width: 100%; aspect-ratio: 1/1; object-fit: cover; display: block;"
            />
          ) : (
            <div style="aspect-ratio: 1/1; background: var(--cream-deep); border: 1px solid var(--line); display: grid; place-items: center;">
              <span style="font-family: ui-monospace, monospace; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--taupe); text-align: center; padding: 0 8px;">Detalhe — bordado dachshund</span>
            </div>
          )}
        </div>
      </div>

      <!-- Coluna de texto -->
      <div class="reveal" style="transition-delay: 100ms;">
        <div style="display: inline-flex; align-items: center; gap: 10px;">
          <img src="/images/dog_taupe.png" alt="" style="width: 26px; opacity: 0.9;" />
          <span style="font-size: 12.5px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--taupe);">{story.eyebrow}</span>
        </div>
        <h2 style="font-size: clamp(2rem, 4.4vw, 3.2rem); margin-top: 18px;">{story.heading}</h2>
        <div style="margin-top: 24px; display: grid; gap: 18px; font-size: 1.08rem; color: var(--text); max-width: 560px;">
          <p set:html={em(story.paragraph1)} />
          <p set:html={em(story.paragraph2)} />
        </div>
        <p style="font-family: var(--serif); font-style: italic; font-size: 1.5rem; color: var(--taupe); margin-top: 28px;">
          {story.quote}
        </p>
      </div>
    </div>
  </div>
</section>
