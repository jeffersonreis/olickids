---
interface NavItem {
  slug: string;
  entry: { label: string; href: string };
}
interface Props {
  nav: NavItem[];
  config: {
    whatsappNumber: string;
    instagramUrl: string;
    instagramHandle: string;
    email: string;
  };
  footer: {
    footerTagline: string;
    footerDescription: string;
  };
}

const { nav, config, footer } = Astro.props;
const waHref = `https://wa.me/${config.whatsappNumber}?text=${encodeURIComponent('Olá! Tenho interesse no Conjunto Térmico da Olic Kids')}`;
const year = new Date().getFullYear();
---

<footer style="background: var(--brown-deep); color: rgba(246,241,232,0.78); padding: 60px 0 36px;">
  <div class="wrap">
    <div class="foot-grid" style="display: grid; gap: 40px; padding-bottom: 40px; border-bottom: 1px solid rgba(246,241,232,0.16);">

      <!-- Brand column -->
      <div>
        <img src="/images/wordmark_cream.png" alt="Olic Kids" style="height: 40px; display: block;" />
        <div style="margin-top: 18px; max-width: 260px; font-size: 14.5px;">{footer.footerDescription}</div>
        <img src="/images/dog_cream.png" alt="" style="margin-top: 22px; width: 76px; opacity: 0.4;" />
      </div>

      <!-- Nav column -->
      <div>
        <div style="font-size: 12.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(201,185,164,0.8); margin-bottom: 16px;">Navegar</div>
        <div style="display: grid; gap: 12px; font-size: 14.5px;">
          {nav.map(({ entry }) => (
            <a href={entry.href} class="foot-link" style="color: rgba(246,241,232,0.78); text-decoration: none;">{entry.label}</a>
          ))}
        </div>
      </div>

      <!-- Contact column -->
      <div>
        <div style="font-size: 12.5px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(201,185,164,0.8); margin-bottom: 16px;">Contato</div>
        <div style="display: grid; gap: 14px; font-size: 14.5px;">
          <a href={waHref} target="_blank" rel="noopener" class="foot-link" style="display: inline-flex; align-items: center; gap: 10px; color: rgba(246,241,232,0.78); text-decoration: none;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="var(--cream)"><path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.978-.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/></svg>
            WhatsApp
          </a>
          <a href={`mailto:${config.email}`} class="foot-link" style="display: inline-flex; align-items: center; gap: 10px; color: rgba(246,241,232,0.78); text-decoration: none;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--cream)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2.5"/><path d="m22 6-10 7L2 6"/>
            </svg>
            {config.email}
          </a>
          <a href={config.instagramUrl} target="_blank" rel="noopener" class="foot-link" style="display: inline-flex; align-items: center; gap: 10px; color: rgba(246,241,232,0.78); text-decoration: none;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--cream)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".6" fill="var(--cream)"/>
            </svg>
            {config.instagramHandle}
          </a>
          <div style="display: inline-flex; align-items: center; gap: 10px;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--cream)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            Blumenau · SC
          </div>
        </div>
      </div>
    </div>

    <!-- Footer bottom -->
    <div class="foot-bottom" style="display: flex; justify-content: space-between; align-items: center; gap: 16px; padding-top: 26px; flex-wrap: wrap;">
      <div style="font-family: var(--serif); font-style: italic; font-size: 1.15rem; color: var(--cream);">
        {footer.footerTagline}
      </div>
      <div style="font-size: 13px; color: rgba(246,241,232,0.55);">
        © {year} Olic Kids. Todos os direitos reservados.
      </div>
    </div>
  </div>
</footer>
